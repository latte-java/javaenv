#!/usr/bin/env bash
set -euo pipefail

JAVAENV_JAVA_DIR="${HOME}/.local/share/java"
JAVAENV_SHIM_DIR="${HOME}/.local/bin"

# Executables to shim (union of bin/ contents across JDK 17, 21, 25)
SHIM_EXECUTABLES=(
  java javac javadoc javap jar jarsigner
  jcmd jconsole jdb jdeprscan jdeps jfr
  jhsdb jimage jinfo jlink jmap jmod
  jpackage jps jrunscript jshell jstack
  jstat jstatd keytool rmiregistry serialver
)

resolve_version() {
  if [[ -n "${JAVAENV_VERSION:-}" ]]; then
    echo "${JAVAENV_VERSION}"
    return
  fi
  local dir="$PWD"
  while [[ "${dir}" != "" ]]; do
    if [[ -f "${dir}/.javaversion" ]]; then
      cat "${dir}/.javaversion"
      return
    fi
    dir="${dir%/*}"
  done
  if [[ -f "${HOME}/.javaversion" ]]; then
    cat "${HOME}/.javaversion"
  fi
}

detect_os() {
  local uname_s
  uname_s="$(uname -s)"
  case "${uname_s}" in
    Linux*)  echo "linux" ;;
    Darwin*) echo "mac" ;;
    *)       echo "Unsupported OS: ${uname_s}" >&2; exit 1 ;;
  esac
}

detect_arch() {
  local uname_m
  uname_m="$(uname -m)"
  case "${uname_m}" in
    x86_64)       echo "x64" ;;
    amd64)        echo "x64" ;;
    aarch64)      echo "aarch64" ;;
    arm64)        echo "aarch64" ;;
    *)            echo "Unsupported architecture: ${uname_m}" >&2; exit 1 ;;
  esac
}

resolve_latest_major() {
  local major="$1"
  local os arch api_url json version
  os="$(detect_os)"
  arch="$(detect_arch)"

  local next_major=$((major + 1))
  api_url="https://api.adoptium.net/v3/info/release_versions?page_size=1&release_type=ga&vendor=eclipse&os=${os}&architecture=${arch}&image_type=jdk&sort_order=DESC&version=%5B${major},${next_major})"

  if ! json="$(curl -fsSL "${api_url}")"; then
    echo "Error: Failed to query Adoptium API for JDK ${major}" >&2
    exit 1
  fi

  # Extract version: build, major, minor, security from first result
  version="$(echo "${json}" \
    | tr -d ' \n' \
    | sed 's/.*"build":\([0-9]*\),.*"major":\([0-9]*\),"minor":\([0-9]*\),.*"security":\([0-9]*\).*/\2.\3.\4+\1/')"

  if [[ -z "${version}" || "${version}" == "${json}" ]]; then
    echo "Error: No GA release found for JDK ${major}" >&2
    exit 1
  fi

  echo "${version}"
}

# NOTE: this function is duplicated in the shim template in cmd_reshim() — keep in sync
resolve_major_to_installed() {
  local major="$1"
  local best=""

  for dir in "${JAVAENV_JAVA_DIR}"/*/; do
    [[ -d "${dir}" ]] || continue
    local name
    name="$(basename "${dir}")"

    # Strip any non-numeric prefix (e.g., "jdk-")
    local ver="${name#"${name%%[0-9]*}"}"

    # Check if this version starts with the requested major
    local dir_major="${ver%%.*}"
    if [[ "${dir_major}" != "${major}" ]]; then
      continue
    fi

    # Compare version segments to find the highest
    if [[ -z "${best}" ]]; then
      best="${name}"
      continue
    fi

    # Split both versions on . and + for numeric comparison
    local IFS='.+'
    local -a cur_parts=(${ver})
    local best_ver="${best#"${best%%[0-9]*}"}"
    local -a best_parts=(${best_ver})
    IFS=' '

    local i
    for ((i = 0; i < ${#cur_parts[@]}; i++)); do
      local cur_seg="${cur_parts[$i]:-0}"
      local best_seg="${best_parts[$i]:-0}"
      if (( cur_seg > best_seg )); then
        best="${name}"
        break
      elif (( cur_seg < best_seg )); then
        break
      fi
    done
  done

  if [[ -z "${best}" ]]; then
    echo ""
    return
  fi

  echo "${best}"
}

update_latte_config() {
  local config_dir="${HOME}/.config/latte/plugins"
  local config_file="${config_dir}/org.lattejava.plugin.java.properties"

  mkdir -p "${config_dir}"

  # Collect unique major versions from installed JDKs, resolve each to the highest installed
  local majors=""
  for dir in "${JAVAENV_JAVA_DIR}"/*/; do
    [[ -d "${dir}" ]] || continue
    local name
    name="$(basename "${dir}")"
    local ver="${name#"${name%%[0-9]*}"}"
    local major="${ver%%.*}"
    if [[ " ${majors} " != *" ${major} "* ]]; then
      majors="${majors} ${major}"
    fi
  done

  # Write config file sorted by major version
  local content=""
  for major in $(echo "${majors}" | tr ' ' '\n' | sort -n); do
    [[ -z "${major}" ]] && continue
    local best
    best="$(resolve_major_to_installed "${major}")"
    if [[ -n "${best}" ]]; then
      content="${content}${major}=${JAVAENV_JAVA_DIR}/${best}"$'\n'
    fi
  done

  printf '%s' "${content}" > "${config_file}"
}

cmd_install_list() {
  local os arch
  os="$(detect_os)"
  arch="$(detect_arch)"

  echo "Available JDK versions from Adoptium (${os}/${arch}):"
  echo ""

  local api_url="https://api.adoptium.net/v3/info/release_versions?page_size=50&release_type=ga&vendor=eclipse&os=${os}&architecture=${arch}&image_type=jdk&sort_order=DESC"
  local json
  if ! json="$(curl -fsSL "${api_url}")"; then
    echo "Error: Failed to query Adoptium API" >&2
    exit 1
  fi

  # Parse JSON with sed/awk — no python3 or jq dependency
  # JSON field order is: build, major, minor, openjdk_version, optional, security, semver
  local lts_versions=" 8 11 17 21 25 "
  local current_major="" prev_version=""

  echo "${json}" \
    | tr -d ' \n' \
    | sed 's/{"build"/\n{"build"/g' \
    | grep '"build"' \
    | sed 's/.*"build":\([0-9]*\),.*"major":\([0-9]*\),"minor":\([0-9]*\),.*"security":\([0-9]*\).*/\1 \2 \3 \4/' \
    | while read -r build major minor security; do
        local version="${major}.${minor}.${security}+${build}"
        # Skip duplicates
        if [[ "${version}" == "${prev_version}" ]]; then
          continue
        fi
        prev_version="${version}"

        if [[ "${major}" != "${current_major}" ]]; then
          if [[ -n "${current_major}" ]]; then
            echo ""
          fi
          if [[ "${lts_versions}" == *" ${major} "* ]]; then
            echo "JDK ${major} (LTS):"
          else
            echo "JDK ${major}:"
          fi
          current_major="${major}"
        fi
        echo "  ${version}"
      done
}

cmd_install() {
  local version="$1"

  # If version has no dots, treat as major version — resolve to latest GA
  if [[ "${version}" != *.* ]]; then
    if [[ ! "${version}" =~ ^[0-9]+$ ]]; then
      echo "Error: Invalid version '${version}'. Use a major version (e.g., 21) or full version (e.g., 21.0.7+6)" >&2
      exit 1
    fi
    echo "Resolving latest JDK ${version}..."
    version="$(resolve_latest_major "${version}")"
    echo "Latest version: ${version}"
  fi

  local os arch release_name url dest tmp_dir archive_ext

  os="$(detect_os)"
  arch="$(detect_arch)"
  release_name="jdk-${version}"
  dest="${JAVAENV_JAVA_DIR}/${version}"

  if [[ -d "${dest}" ]]; then
    echo "JDK ${version} is already installed at ${dest}"
    return 0
  fi

  if [[ "${os}" == "mac" ]]; then
    archive_ext="tar.gz"
  else
    archive_ext="tar.gz"
  fi

  url="https://api.adoptium.net/v3/binary/version/${release_name}/${os}/${arch}/jdk/hotspot/normal/eclipse?project=jdk"

  echo "Downloading JDK ${version} for ${os}/${arch}..."
  tmp_dir="$(mktemp -d)"
  trap 'rm -rf "${tmp_dir}"' EXIT

  local archive="${tmp_dir}/jdk.${archive_ext}"
  if ! curl -fSL -o "${archive}" "${url}"; then
    echo "Error: Failed to download JDK ${version}" >&2
    echo "URL: ${url}" >&2
    exit 1
  fi

  echo "Extracting..."
  mkdir -p "${dest}"
  tar xzf "${archive}" -C "${tmp_dir}"

  # Adoptium tarballs extract to a directory like jdk-17.0.18+8 or jdk-17.0.18+8/Contents/Home on macOS
  local extracted_dir
  extracted_dir="$(find "${tmp_dir}" -maxdepth 1 -type d -name 'jdk-*' | head -1)"

  if [[ -z "${extracted_dir}" ]]; then
    echo "Error: Could not find extracted JDK directory" >&2
    exit 1
  fi

  # On macOS, the JDK is nested under Contents/Home
  if [[ "${os}" == "mac" && -d "${extracted_dir}/Contents/Home" ]]; then
    cp -a "${extracted_dir}/Contents/Home/." "${dest}/"
  else
    cp -a "${extracted_dir}/." "${dest}/"
  fi

  echo "Installed JDK ${version} to ${dest}"
  trap - EXIT
  rm -rf "${tmp_dir}"

  update_latte_config
}

cmd_upgrade() {
  local major="$1"

  if [[ ! "${major}" =~ ^[0-9]+$ ]]; then
    echo "Error: Invalid major version '${major}'. Use a major version number (e.g., 21)" >&2
    exit 1
  fi

  local installed
  installed="$(resolve_major_to_installed "${major}")"
  if [[ -z "${installed}" ]]; then
    echo "No JDK ${major}.x installed. Run: javaenv install ${major}" >&2
    exit 1
  fi

  local installed_ver="${installed#"${installed%%[0-9]*}"}"
  echo "Installed: ${installed_ver}"

  echo "Checking for updates..."
  local latest
  latest="$(resolve_latest_major "${major}")"
  echo "Latest:    ${latest}"

  if [[ "${installed_ver}" == "${latest}" ]]; then
    echo "Already up to date."
    return 0
  fi

  cmd_install "${latest}"
}

cmd_uninstall() {
  local version="$1"
  local dest="${JAVAENV_JAVA_DIR}/${version}"

  if [[ ! -d "${dest}" ]]; then
    echo "JDK ${version} is not installed" >&2
    exit 1
  fi

  rm -rf "${dest}"
  echo "Uninstalled JDK ${version}"

  update_latte_config
}

cmd_versions() {
  if [[ ! -d "${JAVAENV_JAVA_DIR}" ]]; then
    echo "No JDK versions installed"
    return 0
  fi

  local current
  current="$(resolve_version | tr -d '[:space:]')"

  # Resolve major-only to installed for comparison
  if [[ -n "${current}" && "${current}" != *.* ]]; then
    current="$(resolve_major_to_installed "${current}")"
  fi

  for dir in "${JAVAENV_JAVA_DIR}"/*/; do
    [[ -d "${dir}" ]] || continue
    local v
    v="$(basename "${dir}")"
    if [[ "${v}" == "${current}" ]]; then
      echo "* ${v}"
    else
      echo "  ${v}"
    fi
  done
}

cmd_current() {
  local version
  version="$(resolve_version)"

  if [[ -z "${version}" ]]; then
    echo "No Java version set. Create .javaversion or ~/.javaversion" >&2
    exit 1
  fi

  version="$(echo "${version}" | tr -d '[:space:]')"

  # Resolve major-only version to installed
  if [[ "${version}" != *.* ]]; then
    local resolved
    resolved="$(resolve_major_to_installed "${version}")"
    if [[ -z "${resolved}" ]]; then
      echo "No JDK ${version}.x installed. Run: javaenv install ${version}" >&2
      exit 1
    fi
    version="${resolved}"
  fi

  local dest="${JAVAENV_JAVA_DIR}/${version}"
  if [[ ! -d "${dest}" ]]; then
    echo "JDK ${version} is not installed. Run: javaenv install ${version}" >&2
    exit 1
  fi

  echo "${version}"
}

cmd_home() {
  local version
  version="$(resolve_version)"

  if [[ -z "${version}" ]]; then
    echo "No Java version set. Create .javaversion or ~/.javaversion" >&2
    exit 1
  fi

  version="$(echo "${version}" | tr -d '[:space:]')"

  # Resolve major-only version to installed
  if [[ "${version}" != *.* ]]; then
    local resolved
    resolved="$(resolve_major_to_installed "${version}")"
    if [[ -z "${resolved}" ]]; then
      echo "No JDK ${version}.x installed. Run: javaenv install ${version}" >&2
      exit 1
    fi
    version="${resolved}"
  fi

  echo "${JAVAENV_JAVA_DIR}/${version}"
}

validate_version() {
  local version="$1"

  if [[ "${version}" != *.* && ! "${version}" =~ ^[0-9]+$ ]]; then
    echo "Error: Invalid version '${version}'. Use a major version (e.g., 21) or full version (e.g., 21.0.7+6)" >&2
    exit 1
  fi

  if [[ "${version}" == *.* ]]; then
    local dest="${JAVAENV_JAVA_DIR}/${version}"
    if [[ ! -d "${dest}" ]]; then
      echo "JDK ${version} is not installed. Run: javaenv install ${version}" >&2
      exit 1
    fi
  else
    local resolved
    resolved="$(resolve_major_to_installed "${version}")"
    if [[ -z "${resolved}" ]]; then
      echo "No JDK ${version}.x installed. Run: javaenv install ${version}" >&2
      exit 1
    fi
  fi
}

cmd_global() {
  local version="$1"
  validate_version "${version}"
  echo "${version}" > "${HOME}/.javaversion"
  echo "Global Java version set to ${version}"
}

cmd_local() {
  local version="$1"
  validate_version "${version}"
  echo "${version}" > ".javaversion"
  echo "Local Java version set to ${version} ($(pwd)/.javaversion)"
}

cmd_shell() {
  local version="$1"
  validate_version "${version}"
  echo "${version}"
}

cmd_init() {
  local shell_name="${1:-}"

  # Auto-detect shell from SHELL env var if not specified
  if [[ -z "${shell_name}" ]]; then
    shell_name="$(basename "${SHELL:-bash}")"
  fi

  case "${shell_name}" in
    bash|zsh)
      cat <<'INIT'
export JAVA_HOME="$(javaenv home 2>/dev/null)"
javaenv() {
  local command="${1:-}"
  if [[ "${command}" == "shell" ]]; then
    shift
    if [[ "${1:-}" == "--unset" ]]; then
      unset JAVAENV_VERSION
      echo "Cleared JAVAENV_VERSION"
    elif [[ -z "${1:-}" ]]; then
      if [[ -n "${JAVAENV_VERSION:-}" ]]; then
        echo "${JAVAENV_VERSION}"
      else
        echo "No shell version set"
      fi
    else
      JAVAENV_VERSION="$(command javaenv shell "$1")" && export JAVAENV_VERSION
      export JAVA_HOME="$(command javaenv home 2>/dev/null)"
    fi
  else
    command javaenv "$@"
    if [[ "${command}" == "global" || "${command}" == "local" ]]; then
      export JAVA_HOME="$(command javaenv home 2>/dev/null)"
    fi
  fi
}
INIT
      ;;
    fish)
      cat <<'INIT'
if set -l jhome (javaenv home 2>/dev/null)
  set -gx JAVA_HOME $jhome
end
function javaenv
  set -l command $argv[1]
  if test "$command" = "shell"
    if test (count $argv) -lt 2
      if set -q JAVAENV_VERSION
        echo $JAVAENV_VERSION
      else
        echo "No shell version set"
      end
    else if test "$argv[2]" = "--unset"
      set -e JAVAENV_VERSION
      echo "Cleared JAVAENV_VERSION"
    else
      set -gx JAVAENV_VERSION (command javaenv shell $argv[2])
      if set -l jhome (command javaenv home 2>/dev/null)
        set -gx JAVA_HOME $jhome
      end
    end
  else
    command javaenv $argv
    if test "$command" = "global" -o "$command" = "local"
      if set -l jhome (command javaenv home 2>/dev/null)
        set -gx JAVA_HOME $jhome
      end
    end
  end
end
INIT
      ;;
    *)
      echo "Error: Unsupported shell '${shell_name}'. Supported: bash, zsh, fish" >&2
      exit 1
      ;;
  esac
}

cmd_doctor() {
  local issues=0

  echo "javaenv doctor"
  echo "=============="
  echo ""

  # Check javaenv is in PATH
  if command -v javaenv &>/dev/null; then
    echo "[OK] javaenv found at $(command -v javaenv)"
  else
    echo "[ERROR] javaenv is not in PATH"
    issues=$((issues + 1))
  fi

  # Check shim directory exists
  if [[ -d "${JAVAENV_SHIM_DIR}" ]]; then
    echo "[OK] Shim directory exists (${JAVAENV_SHIM_DIR})"
  else
    echo "[ERROR] Shim directory missing (${JAVAENV_SHIM_DIR})"
    echo "  Run: javaenv reshim"
    issues=$((issues + 1))
  fi

  # Check shim directory is in PATH
  if [[ ":${PATH}:" == *":${JAVAENV_SHIM_DIR}:"* ]]; then
    echo "[OK] Shim directory is in PATH"
  else
    echo "[ERROR] Shim directory (${JAVAENV_SHIM_DIR}) is not in PATH"
    echo "  Add ${JAVAENV_SHIM_DIR} to your PATH"
    issues=$((issues + 1))
  fi

  # Check shims exist
  if [[ -x "${JAVAENV_SHIM_DIR}/java" ]]; then
    echo "[OK] Java shim exists"
  else
    echo "[ERROR] Java shim not found at ${JAVAENV_SHIM_DIR}/java"
    echo "  Run: javaenv reshim"
    issues=$((issues + 1))
  fi

  # Check shims come before system java in PATH
  local java_path
  java_path="$(command -v java 2>/dev/null || true)"
  if [[ -n "${java_path}" ]]; then
    if [[ "${java_path}" == "${JAVAENV_SHIM_DIR}/java" ]]; then
      echo "[OK] javaenv shim is first java in PATH"
    else
      echo "[WARN] java resolves to ${java_path} (not the javaenv shim)"
      echo "  Ensure ${JAVAENV_SHIM_DIR} appears before $(dirname "${java_path}") in PATH"
      issues=$((issues + 1))
    fi
  else
    echo "[WARN] No java found in PATH"
  fi

  # Check java directory exists
  if [[ -d "${JAVAENV_JAVA_DIR}" ]]; then
    local version_count
    version_count=$(find "${JAVAENV_JAVA_DIR}" -mindepth 1 -maxdepth 1 -type d 2>/dev/null | wc -l | tr -d ' ')
    echo "[OK] Java directory exists with ${version_count} version(s) installed"
  else
    echo "[WARN] Java directory missing (${JAVAENV_JAVA_DIR})"
    echo "  Run: javaenv install <version>"
  fi

  # Check version resolution
  local version
  version="$(resolve_version)"
  if [[ -n "${version}" ]]; then
    local source="unknown"
    if [[ -n "${JAVAENV_VERSION:-}" ]]; then
      source="JAVAENV_VERSION"
    else
      local search_dir="$PWD"
      while [[ "${search_dir}" != "" ]]; do
        if [[ -f "${search_dir}/.javaversion" ]]; then
          source="${search_dir}/.javaversion"
          break
        fi
        search_dir="${search_dir%/*}"
      done
      if [[ "${source}" == "unknown" && -f "${HOME}/.javaversion" ]]; then
        source="~/.javaversion"
      fi
    fi
    echo "[OK] Version ${version} resolved from ${source}"

    # Check if resolved version is actually installed
    version="$(echo "${version}" | tr -d '[:space:]')"
    if [[ "${version}" != *.* ]]; then
      local resolved
      resolved="$(resolve_major_to_installed "${version}")"
      if [[ -n "${resolved}" ]]; then
        echo "[OK] Major version ${version} resolves to installed ${resolved}"
      else
        echo "[ERROR] No installed JDK matches major version ${version}"
        echo "  Run: javaenv install ${version}"
        issues=$((issues + 1))
      fi
    else
      if [[ -d "${JAVAENV_JAVA_DIR}/${version}" ]]; then
        echo "[OK] JDK ${version} is installed"
      else
        echo "[ERROR] JDK ${version} is not installed"
        echo "  Run: javaenv install ${version}"
        issues=$((issues + 1))
      fi
    fi
  else
    echo "[WARN] No Java version configured"
    echo "  Run: javaenv global <version>"
  fi

  # Check JAVA_HOME
  if [[ -n "${JAVA_HOME:-}" ]]; then
    if [[ -d "${JAVA_HOME}" ]]; then
      local expected_home
      expected_home="$(cmd_home 2>/dev/null || true)"
      if [[ -n "${expected_home}" && "${JAVA_HOME}" == "${expected_home}" ]]; then
        echo "[OK] JAVA_HOME is set correctly (${JAVA_HOME})"
      elif [[ -n "${expected_home}" ]]; then
        echo "[WARN] JAVA_HOME (${JAVA_HOME}) does not match javaenv home (${expected_home})"
        echo "  Add eval \"\$(javaenv init)\" to your shell profile"
        issues=$((issues + 1))
      else
        echo "[WARN] JAVA_HOME is set (${JAVA_HOME}) but javaenv cannot determine expected value"
      fi
    else
      echo "[ERROR] JAVA_HOME is set to a non-existent directory: ${JAVA_HOME}"
      issues=$((issues + 1))
    fi
  else
    echo "[WARN] JAVA_HOME is not set"
    echo "  Add eval \"\$(javaenv init)\" to your shell profile"
  fi

  echo ""
  if [[ ${issues} -eq 0 ]]; then
    echo "No issues found."
  else
    echo "${issues} issue(s) found."
  fi
}

cmd_reshim() {
  mkdir -p "${JAVAENV_SHIM_DIR}"

  for exe in "${SHIM_EXECUTABLES[@]}"; do
    local shim_path="${JAVAENV_SHIM_DIR}/${exe}"

    # Don't overwrite non-shim files
    if [[ -f "${shim_path}" && ! -L "${shim_path}" ]]; then
      if ! head -2 "${shim_path}" | grep -q "javaenv shim"; then
        echo "Skipping ${exe}: ${shim_path} exists and is not a javaenv shim" >&2
        continue
      fi
    fi

    cat > "${shim_path}" <<'SHIM'
#!/usr/bin/env bash
# javaenv shim
set -euo pipefail

JAVAENV_JAVA_DIR="${HOME}/.local/share/java"

resolve_version() {
  if [[ -n "${JAVAENV_VERSION:-}" ]]; then
    echo "${JAVAENV_VERSION}"
    return
  fi
  local dir="$PWD"
  while [[ "${dir}" != "" ]]; do
    if [[ -f "${dir}/.javaversion" ]]; then
      cat "${dir}/.javaversion"
      return
    fi
    dir="${dir%/*}"
  done
  if [[ -f "${HOME}/.javaversion" ]]; then
    cat "${HOME}/.javaversion"
  fi
}

# NOTE: keep in sync with resolve_major_to_installed() in the main script
resolve_major_to_installed() {
  local major="$1"
  local best=""

  for dir in "${JAVAENV_JAVA_DIR}"/*/; do
    [[ -d "${dir}" ]] || continue
    local name
    name="$(basename "${dir}")"
    local ver="${name#"${name%%[0-9]*}"}"
    local dir_major="${ver%%.*}"
    if [[ "${dir_major}" != "${major}" ]]; then
      continue
    fi

    if [[ -z "${best}" ]]; then
      best="${name}"
      continue
    fi

    local IFS='.+'
    local -a cur_parts=(${ver})
    local best_ver="${best#"${best%%[0-9]*}"}"
    local -a best_parts=(${best_ver})
    IFS=' '

    local i
    for ((i = 0; i < ${#cur_parts[@]}; i++)); do
      local cur_seg="${cur_parts[$i]:-0}"
      local best_seg="${best_parts[$i]:-0}"
      if (( cur_seg > best_seg )); then
        best="${name}"
        break
      elif (( cur_seg < best_seg )); then
        break
      fi
    done
  done

  echo "${best}"
}

version="$(resolve_version)"
if [[ -z "${version}" ]]; then
  echo "javaenv: no .javaversion file found in directory hierarchy or ~/.javaversion" >&2
  exit 1
fi

version="$(echo "${version}" | tr -d '[:space:]')"

# If version has no dots, resolve to highest installed major match
if [[ "${version}" != *.* ]]; then
  resolved="$(resolve_major_to_installed "${version}")"
  if [[ -z "${resolved}" ]]; then
    echo "javaenv: no JDK ${version}.x installed. Run: javaenv install ${version}" >&2
    exit 1
  fi
  version="${resolved}"
fi

exe_name="$(basename "$0")"
exe_path="${JAVAENV_JAVA_DIR}/${version}/bin/${exe_name}"

if [[ ! -x "${exe_path}" ]]; then
  echo "javaenv: ${exe_name} not found for JDK ${version}" >&2
  echo "Run: javaenv install ${version}" >&2
  exit 1
fi

exec "${exe_path}" "$@"
SHIM
    chmod +x "${shim_path}"
  done

  echo "Shims installed to ${JAVAENV_SHIM_DIR}"
}

usage() {
  cat <<EOF
Usage: javaenv <command> [args]

Commands:
  install <version>     Install a JDK version (e.g., 21 or 21.0.7+6)
  install -l|--list     List available JDK versions from Adoptium
  upgrade <major>       Upgrade an installed JDK to the latest patch
  uninstall <version>   Remove an installed JDK version
  global <version>      Set the global Java version (~/.javaversion)
  local <version>       Set the local Java version (./.javaversion)
  shell <version>       Set Java version for the current shell session
  shell --unset         Clear the shell version override
  init [shell]          Output shell code to set JAVA_HOME (bash/zsh/fish)
  versions              List installed JDK versions
  current               Show the currently active JDK version
  home                  Print JAVA_HOME for the current version
  doctor                Diagnose common setup problems
  reshim                Regenerate shims in ~/.local/bin
  help                  Show this help message

Version is resolved from .javaversion in the current directory
(searching up), falling back to ~/.javaversion.
A major version (e.g., 21) resolves to the latest installed patch.
EOF
}

main() {
  if [[ $# -lt 1 ]]; then
    usage
    exit 1
  fi

  local command="$1"
  shift

  case "${command}" in
    install)
      if [[ $# -lt 1 ]]; then
        echo "Usage: javaenv install <version>" >&2
        echo "       javaenv install -l|--list" >&2
        exit 1
      fi
      if [[ "$1" == "-l" || "$1" == "--list" ]]; then
        cmd_install_list
      else
        cmd_install "$1"
        cmd_reshim
      fi
      ;;
    upgrade)
      if [[ $# -lt 1 ]]; then
        echo "Usage: javaenv upgrade <major>" >&2
        exit 1
      fi
      cmd_upgrade "$1"
      ;;
    uninstall)
      if [[ $# -lt 1 ]]; then
        echo "Usage: javaenv uninstall <version>" >&2
        exit 1
      fi
      cmd_uninstall "$1"
      ;;
    global)
      if [[ $# -lt 1 ]]; then
        echo "Usage: javaenv global <version>" >&2
        exit 1
      fi
      cmd_global "$1"
      ;;
    local)
      if [[ $# -lt 1 ]]; then
        echo "Usage: javaenv local <version>" >&2
        exit 1
      fi
      cmd_local "$1"
      ;;
    versions)
      cmd_versions
      ;;
    current)
      cmd_current
      ;;
    home)
      cmd_home
      ;;
    shell)
      if [[ $# -lt 1 ]]; then
        echo "Usage: javaenv shell <version>" >&2
        echo "       javaenv shell --unset" >&2
        echo "Note: requires javaenv init in your shell profile" >&2
        exit 1
      fi
      cmd_shell "$1"
      ;;
    init)
      cmd_init "${1:-}"
      ;;
    doctor)
      cmd_doctor
      ;;
    reshim)
      cmd_reshim
      ;;
    help|--help|-h)
      usage
      ;;
    *)
      echo "Unknown command: ${command}" >&2
      usage
      exit 1
      ;;
  esac
}

main "$@"
